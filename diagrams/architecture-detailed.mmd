flowchart LR
  U[User / Sarthi] --> M[Main Agent\nOrchestrator]
  M --> P[Planner]

  subgraph DEV[On-Device Control Plane (Host)]
    direction TB
    M
    P
    MOD[Moderator\nprogress + feedback]
    ARC[Architect\nupgrade planning]
    JAN[Janitor\nhygiene / cleanup]
    MEM[(Memory & Learnings)]
    AUD[(Audit & State)]
    CRON[(Schedulers)]
    SIGN[Host TX Signer\nkey custody]
  end

  subgraph SBX[Sandbox Zone (Isolated Execution)]
    direction TB
    RSBX[Research Sandbox]
    CSBX[Coder Sandbox]
    TXSBX[TX Sandbox\nNO key material]
    AFSBX[Antfarm Swarm Sandbox\nEphemeral workers]
  end

  P --> RSBX
  P --> CSBX
  P --> TXSBX
  P --> AFSBX

  TXSBX -->|sign request| SIGN
  SIGN -->|signature only| TXSBX

  MOD -->|status/feedback| M
  ARC -->|upgrade proposals| M
  M -->|cleanup request| JAN
  M --> MEM
  M --> AUD
  M --> CRON

  style SBX fill:#eef7ff,stroke:#2563eb,stroke-width:1px
  style TXSBX fill:#fff1f2,stroke:#b91c1c,stroke-width:2px
  style SIGN fill:#fee2e2,stroke:#b91c1c,stroke-width:2px
  style MOD fill:#ecfeff,stroke:#0e7490,stroke-width:2px
  style ARC fill:#ede9fe,stroke:#6d28d9,stroke-width:2px
